version: "3"

struct S1 {
    s0 @ 0: u8,
    s1 @ 1: i8,
}

struct S2 {
    s0 @ 2: u16,
    s1 @ 3: i16,
}

struct S3 {
    s0 @ 4: u32,
    s1 @ 5: i32,
}

struct S4 {
    s0 @ 6: u64,
    s1 @ 7: i64,
}

struct S5 {
    s0 @ 8: f32,
    s1 @ 9: f64,
}

struct S6 {
    s0 @ 10: str,
}

enum E {
    S0 = 0,
    S1 = 1,
    S2 = 2,
}

struct S7 {
    s1 @ 0: E,
}

struct S8 {
    s1 @ 0: [u8, 4],
}

